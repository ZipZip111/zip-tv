{
  "name": "ultratv-desktop",
  "version": "0.1.0",
  "description": "Ultra TV desktop wrapper — Electron shell around the web app with native codecs.",
  "main": "main.cjs",
  "scripts": {
    "build:web": "cd ../web && npm run build",
    "dev": "cross-env SV_DEV=1 electron .",
    "package:mac": "npm run build:web && electron-builder --mac",
    "package:win": "npm run build:web && electron-builder --win",
    "package:linux": "npm run build:web && electron-builder --linux",
    "icons": "electron-icon-builder --input=../docs/redesign/logo.svg --output=./build --flatten"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "github:castlabs/electron-releases#v33.4.11+wvcus",
    "electron-builder": "^25.1.8",
    "electron-icon-builder": "^2.0.1"
  },
  "build": {
    "appId": "com.ultratv.desktop",
    "productName": "Ultra TV",
    "files": [
      "main.cjs",
      "preload.cjs",
      "../web/dist/**/*"
    ],
    "extraMetadata": { "main": "main.cjs" },
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "asar": true,
    "mac": {
      "category": "public.app-category.entertainment",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "AudioVideo"
    }
  }
}
